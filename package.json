{
    "name": "teacher_corner2.0",
    "version": "15.1.0",
    "description": "Teacher Corner Application",
    "author": "ThinkTac IT Team",
    "private": true,
    "scripts": {
        "ng": "ng",
        "start": "set NODE_OPTIONS=--max-old-space-size=6144 && ng serve",
        "build": "set NODE_OPTIONS=--max-old-space-size=6144 && ng build",
        "test": "set NODE_OPTIONS=--max-old-space-size=6144 && ng test",
        "start:electron": "electron main.js",
        "host": "firebase deploy --only hosting",
        "bp": "ng build && npm run host",
        "watch": "ng build --watch --configuration development",
        "lint": "ng lint",
        "lint:fix": "ng lint --fix",
        "prettify": "prettier --write .",
        "deploy-sandbox": "ng build --configuration development --aot --output-path=\"dist/sandbox-teachercorner\" && copy \"sandbox-firebase.json\" \"firebase.json\" && firebase deploy --only hosting:sandbox-teachercorner --project backup",
        "deploy-staging": "ng build --configuration production --aot --output-path=\"dist/review-teachercorner\" && copy \"staging-firebase.json\" \"firebase.json\" && firebase deploy --only hosting:review-teachercorner --project default",
        "deploy-jigyaasa": "ng build --configuration jigyaasa --aot --output-path=\"dist/jigyasa-teachercorner\" && copy \"jigyaasa-firebase.json\" \"firebase.json\" && firebase deploy --only hosting:jigyasa-teachercorner --project jigyaasa",
        "deploy-all": "npm run deploy-sandbox && npm run deploy-staging && npm run deploy-jigyaasa",
        "start:electron:offline": "ng build --configuration production --output-path=dist/review-teachercorner && electron ."
    },
